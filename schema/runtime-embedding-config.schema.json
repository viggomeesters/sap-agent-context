{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SAP Agent Context local embedding runtime config",
  "type": "object",
  "required": ["provider", "model", "dimension", "cache_path"],
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["fastembed", "sentence-transformers", "ollama", "custom-local"],
      "default": "fastembed"
    },
    "model": {"type": "string", "default": "BAAI/bge-small-en-v1.5"},
    "dimension": {"type": "integer", "default": 384},
    "cache_path": {"type": "string"},
    "batch_size": {"type": "number"},
    "normalize": {"type": "boolean"},
    "offline_only": {"type": "boolean"}
  },
  "additionalProperties": false
}
