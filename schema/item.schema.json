{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SAP Agent Context item record",
  "type": "object",
  "required": [
    "id",
    "kind",
    "title",
    "summary",
    "status",
    "access",
    "requires_login",
    "topics",
    "used_for",
    "source_ids",
    "claim_ids",
    "freshness",
    "retrieval"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string"},
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "status": {"type": "string", "enum": ["active", "draft", "deprecated"]},
    "access": {"type": "string", "enum": ["public", "gated", "internal_derived"]},
    "requires_login": {"type": "boolean"},
    "sap_product": {"type": "string"},
    "topics": {"type": "array", "minItems": 1},
    "used_for": {"type": "array", "minItems": 1},
    "source_path": {"type": "string"},
    "source_ids": {"type": "array", "minItems": 1},
    "claim_ids": {"type": "array"},
    "relation_ids": {"type": "array"},
    "freshness": {"type": "object"},
    "retrieval": {"type": "object"}
  }
}
